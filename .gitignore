node_modules/
dist/
release-artifacts/
*.tsbuildinfo
.DS_Store
.env
.worktrees/

# Claude Code harness scratch — per-checkout state, never shared.
.claude/scheduled_tasks.lock
.claude/*.lock

# Go TUI build artifact (scripts/remote-access/tui/) — source lives in main.go;
# build locally with `go run .` or `go build .` when you want a binary.
scripts/remote-access/tui/tui

# Mobile uploads landing dir — files arrive here per-session via the streamer's
# /api/sessions/<id>/files endpoint and are referenced by absolute path in the
# JSONL. Local-only state; never shared.
.threadbase-uploads/

# Belt-and-suspenders for the public flip — nothing tracked today matches any
# of these, but listing them prevents accidental `git add .` of:
#
# - menubar-signing.env: Apple Developer ID + App Store Connect API key vars
#   sourced by scripts/deploy.sh during a signed menubar build. Lives at
#   ~/.threadbase/menubar-signing.env in normal use; only here in case a
#   developer copies it into the repo root for testing.
# - *.p12 / *.pem: signing certs and private keys (Apple Developer ID,
#   Cloudflare client certs, anything else). Never belongs in version control.
# - releases/: matches ~/.threadbase/releases/ if the install dir is ever
#   symlinked into the repo root for inspection.
menubar-signing.env
*.p12
*.pem
releases/

# SHA stamps written by scripts/build-vendor.mjs to skip re-installing vendored
# submodules when their pointer hasn't moved.
.vendor-stamps/
